{
  "files": ["./shared/src/index.ts"],
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "module": "Preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": []
  },
  "exclude": [
    "shared/src/**/*.test.ts",
    "shared/src/**/*.test.tsx",
    "shared/src/**/*.spec.ts",
    "shared/src/**/*.spec.tsx"
  ]
}
